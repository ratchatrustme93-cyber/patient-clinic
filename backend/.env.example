# คัดลอกเป็น .env แล้วใส่ค่าจริง — ห้าม commit .env
# สร้างกุญแจ:  openssl rand -base64 32     (JWT ใช้ 48)

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/patient_clinic?schema=public"

# ใช้เซ็น JWT — เปลี่ยนค่านี้ = ทุกคนต้อง login ใหม่
JWT_SECRET=""

# กุญแจเข้ารหัสข้อมูลอ่อนไหวของคนไข้ (เลขบัตร, ที่อยู่, ผลวินิจฉัย ฯลฯ)
# ต้องเป็นคนละใบกัน · ใบละ 32 ไบต์ base64
# ⚠️ กุญแจหาย = ข้อมูลกู้ไม่ได้ถาวร
# ⚠️ ห้ามเก็บกุญแจไว้ที่เดียวกับ backup ของ DB
ENCRYPTION_KEY=""
BLIND_INDEX_KEY=""

# origin ของ frontend ที่อนุญาตให้เรียก API (คั่นด้วย , ได้)
CORS_ORIGIN="http://localhost:5173"

PORT=3008
